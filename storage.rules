rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 100/100 Security: Private Protected Folders
    match /users/{userId}/cases/{caseId}/{fileName} {
      // Allow read/write ONLY if authorized and accessing their own child photo
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Default: Deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
