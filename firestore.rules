rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 100/100 Security: Deny all reads/writes by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Granular Row-Level Security for User Cases
    match /users/{userId}/cases/{caseId} {
      // Users can ONLY read and write their own rescue reports
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Optional: Public Read if we wanted "Public Active Search" feature in future
    // match /public_cases/{caseId} {
    //   allow read: if true;
    //   allow write: if request.auth != null;
    // }
  }
}
